# LLM Providers (set the one you use)
OPENAI_API_KEY=
GROQ_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
XAI_API_KEY=
OPENROUTER_API_KEY=

# Optional: cap per-request token budget for low-TPM providers like Groq.
# Example: 6000
TRADINGAGENTS_MAX_TPM=

# Optional: when TRADINGAGENTS_MAX_TPM is enabled on Groq, use this model
# instead of llama-3.1-8b-instant for quick-thinking/tool-calling steps.
TRADINGAGENTS_GROQ_CONSTRAINED_QUICK_MODEL=llama-3.3-70b-versatile
